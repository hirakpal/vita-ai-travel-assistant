# Choose one provider: openai | gemini | anthropic | openrouter
# Leave blank to auto-infer from whichever API key below is set.
LLM_PROVIDER=
LLM_MODEL=

OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional: enables real-distance lookups for the transportation guardrail.
GOOGLE_MAPS_API_KEY=

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

CHROMA_PERSIST_DIR=vectordb/store
